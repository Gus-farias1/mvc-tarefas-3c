<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title> Integração com SGBD </title>
</head>

<body>
   <h1><%= tituloLista %></h1>

    <button onclick="window.location='/cadastro'">Nova Tarefa</button>
    <% if (exibindoEscondidas) { %>
        <button onclick="window.location='/'">Ver tarefas visíveis</button>
    <% } else { %>
        <button onclick="window.location='/escondidas'">Ver tarefas escondidas</button>
    <% } %>

    <br>
    <br>

   <table>
    <thead>
        <tr>
            <th>Código</th>
            <th>Tarefa</th>
            <th>Prazo</th>
            <th>Situação</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
<% if(Array.isArray(linhasTabela) && linhasTabela.length > 0){
    let situacao = ["Cancelada", "Pendente","Iniciada","Finalizada","Em Atraso","Escondida"];
    
    linhasTabela.forEach((item)=>{
    %>
        <tr>
            <td><%= item.id_tarefa %></td>
            <td><%= item.nome_tarefa %></td>
            <td><%= moment(item.prazo_tarefa).format('L') %></td>
            <td><%= situacao[item.situacao_tarefa] %></td>
            <td>
                <a href="/alterar?id=<%= item.id_tarefa %>">Editar</a>
                <% if (exibindoEscondidas) { %>
                    <a href="/restaurar?id=<%= item.id_tarefa %>">Restaurar</a>
                <% } else { %>
                    <a href="/delete-soft?id=<%= item.id_tarefa %>">Esconder</a>
                <% } %>
                <a href="/delete?id=<%= item.id_tarefa %>">Excluir</a>
            </td>
        </tr>
    <% 
        });
        } else { %>
        <tr>
            <td colspan="5">Não há dados para exibir</td>
        </tr>    
    <% } %>    
    </tbody>
   </table>

</body>

</html>
